{
	"comments": {
		"lineComment": { "noIndent": false, "comment": "#" },
	},

	// symbols used as brackets
	"brackets": [
		[ "{" ,  "}" ],
		[ "[" ,  "]" ],
		[ "(" ,  ")" ],
		// [ "[[", "]]" ],
		// [ "((", "))" ],
	],

	// symbols that are auto closed when typing
	"autoClosingPairs": [
		{ "open": "{" , "close": "}" },
		{ "open": "[" , "close": "]" },
		{ "open": "(" , "close": ")" },
		{ "open": "\"", "close": "\"", "notIn": [ "comment" ] },
		{ "open": "'" , "close": "'" , "notIn": [ "comment" ] },
		{ "open": "`" , "close": "`" , "notIn": [ "comment" ] },
	],

	// symbols that can be used to surround a selection
	"surroundingPairs": [
		[ "{" , "}"  ],
		[ "[" , "]"  ],
		[ "(" , ")"  ],
		[ "\"", "\"" ],
		[ "'" , "'"  ],
		[ "`" , "`"  ],
	]
}
