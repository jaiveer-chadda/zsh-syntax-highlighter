{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "zsh",
	"scopeName": "source.zsh",

	"patterns": [
		{ "include": "#keywords" },
		{ "include": "#strings"  }
	],

	"repository": {

		"keywords": {
			"patterns": [{
				"name"	: "keyword.control.zsh",
				"match"	: "\\b(if|while|for|return)\\b"
			}]
		},

		"strings": {
			"name": "string.quoted.double.zsh",
			"begin"	: "\"",
			"end"		: "\"",
			"patterns": [{
					"name"	: "constant.character.escape.zsh",
					"match"	: "\\\\."
			}]
		}

	}
}
